{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://unmocking-yesenia-odoriferously.ngrok-free.dev/api"
      }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://unmocking-yesenia-odoriferously.ngrok-free.dev/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
