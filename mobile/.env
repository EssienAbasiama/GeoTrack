# Local Expo Go / dev-server config (loaded automatically by Expo).
# Point the app at the public ngrok URL of the Laravel API.
# If ngrok restarts and the URL changes, update this line and restart `expo start`.
EXPO_PUBLIC_API_BASE_URL=https://unmocking-yesenia-odoriferously.ngrok-free.dev/api

# Google Maps key (Android needs it for PROVIDER_GOOGLE; iOS Expo Go uses Apple Maps).
# Get one from Google Cloud Console > APIs > "Maps SDK for Android" > create API key.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDYBHxkNOhOzQ_ZD7Qy71ib50c6DRuF_as
